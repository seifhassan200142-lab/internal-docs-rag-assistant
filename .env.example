# App
APP_NAME=internal-docs-rag-assistant
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_API_URL=http://localhost:8000
UPLOAD_DIR=data/uploads
INDEX_DIR=data/index

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=internal_docs_chunks

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# Retrieval
RETRIEVAL_TOP_K=6
RRF_K=60
MIN_CONTEXT_CHUNKS=1

# Optional reranking
ENABLE_RERANKING=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# LLM provider: openai | groq | ollama | openai_compatible
LLM_PROVIDER=openai
REQUEST_TIMEOUT_SECONDS=60

# OpenAI-compatible OpenAI API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Groq uses an OpenAI-compatible API shape
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# Any other OpenAI-compatible endpoint
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=

# Ollama local model
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
